rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Checks if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Checks if user matches the document ID
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users and their data
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Activities log sub-collection
      match /activities/{activityId} {
        allow read, write: if isOwner(userId);
      }

      // Daily summaries
      match /dailySummaries/{date} {
        allow read, write: if isOwner(userId);
      }

      // Weekly summaries
      match /weeklySummaries/{weekId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Emission factors (Global public read, no client writes)
    match /emissionFactors/{factorSetVersion} {
      allow read: if true;
      allow write: if false;
    }

    // Cohort leaderboards (Public read for authenticated users, no client writes)
    match /cohortLeaderboard/{cohortKey} {
      allow read: if isAuthenticated();
      allow write: if false;
    }
  }
}
